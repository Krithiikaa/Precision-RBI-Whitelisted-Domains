# ============================================================================
# Precision RBI — Environment Configuration
# Copy to .env and edit. NEVER commit the real .env.
# ============================================================================

# --- Network ---------------------------------------------------------------
# The LAN IP (or hostname) of THIS server, as reachable by client browsers.
# The extension builds wss://${SERVER_IP}/render/{sessionId} from this value.
SERVER_IP=10.225.247.38
SERVER_PORT=443

# --- Capacity (tuned for Ryzen 3 7320U / 7.21 GiB RAM dev box) --------------
MAX_SESSIONS=7
CONTAINER_MEMORY=536870912          # 512 MB in bytes
CONTAINER_CPU_QUOTA=50000           # 0.5 core (quota/period)
CONTAINER_CPU_PERIOD=100000
CAPACITY_WARN_AT=5

# --- Per-session frame-streamer internal port pool (rbi-net only) ----------
FRAME_PORT_MIN=7000
FRAME_PORT_MAX=7100

# --- Streaming / encoding --------------------------------------------------
JPEG_QUALITY=78
TARGET_FPS=20
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=720

# --- RBI container image ---------------------------------------------------
RBI_IMAGE=precision-rbi-container
RBI_NETWORK=rbi-net

# --- Backing store ---------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Session policy --------------------------------------------------------
HEARTBEAT_TIMEOUT_MS=30000          # watchdog kills sessions idle this long
SESSION_VERSION=2.0.0

# --- Admin console ---------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=precision2024
